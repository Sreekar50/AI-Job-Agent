# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobagent:jobagent@localhost:5432/jobagent
DATABASE_URL_SYNC=postgresql://jobagent:jobagent@localhost:5432/jobagent

# ─── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=YOUR_API_KEY

# ─── Redis (for Celery job queue) ────────────────────────────────────────────
REDIS_URL=YOUR_REDIS_URL

# ─── Browserless (optional – for cloud browser) ──────────────────────────────
# If not set, falls back to local Playwright
BROWSERLESS_URL=wss://chrome.browserless.io?token=YOUR_TOKEN

# ─── App Settings ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=RANDOM_SECRET_KEY using python -c "import secrets; print(secrets.token_hex(32))"

# ─── HITL Settings ───────────────────────────────────────────────────────────
HITL_TIMEOUT_SECONDS=30

# ─── Agent Settings ──────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
MAX_CONCURRENT_JOBS=3
AGENT_HEADLESS=true
